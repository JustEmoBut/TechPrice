# MongoDB Atlas bağlantı URL'si
# Atlas panelinden "Connect > Drivers" altında alabilirsin
# Şifrede özel karakter varsa encode et:
#   python -c "from urllib.parse import quote_plus; print(quote_plus('şifren'))"
MONGODB_URL=mongodb+srv://kullanici:sifre@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB veritabanı adı (Atlas'ta otomatik oluşturulur)
MONGODB_DB_NAME=TechPriceDB

# CORS — frontend'in çalıştığı adres(ler), JSON liste formatında
# Birden fazla: CORS_ORIGINS=["http://localhost:3000","https://siten.com"]
CORS_ORIGINS=["http://localhost:3000"]

# Scraper
# SCRAPER_DELAY_MIN/MAX: iki istek arasındaki bekleme süresi (saniye)
#   Düşük değer → daha hızlı ama ban riski artar
#   Önerilen aralık: 2.0 - 5.0
SCRAPER_DELAY_MIN=2.0
SCRAPER_DELAY_MAX=5.0

# Kategori başına çekilecek maksimum ürün sayısı (0 = sınırsız)
SCRAPER_MAX_PRODUCTS_PER_CATEGORY=0

# Sayfa yüklenme zaman aşımı (saniye)
#   Yavaş bağlantıda artır, örn: 60
SCRAPER_PAGE_TIMEOUT=30

# Scheduler (otomatik scraping)
# SCHEDULER_ENABLED: true = açık, false = kapalı
# SCHEDULER_CRON_DAY: mon tue wed thu fri sat sun (veya * = her gün)
# SCHEDULER_CRON_HOUR: 0-23
# SCHEDULER_CRON_MINUTE: 0-59
#
# Örnekler:
#   Her Pazar 12:00 (varsayılan) → DAY=sun     HOUR=12 MINUTE=0
#   Her gün gece yarısı          → DAY=*       HOUR=0  MINUTE=0
#   Hafta içi her gün 03:30      → DAY=mon-fri HOUR=3  MINUTE=30
SCHEDULER_ENABLED=true
SCHEDULER_CRON_DAY=sun
SCHEDULER_CRON_HOUR=12
SCHEDULER_CRON_MINUTE=0

# Loglama seviyesi: DEBUG | INFO | WARNING | ERROR
#   DEBUG → tüm detaylar (geliştirme için)
#   INFO  → normal çalışma logları (varsayılan)
#   WARNING/ERROR → sadece sorunlar (üretim için)
LOG_LEVEL=INFO
