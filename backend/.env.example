# MongoDB Atlas bağlantı URL'si
# Özel karakterleri encode et: python -c "from urllib.parse import quote_plus; print(quote_plus('şifre'))"
MONGODB_URL=mongodb+srv://kullanici:sifre@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB veritabanı adı
MONGODB_DB_NAME=TechPriceDB

# API ayarları
API_HOST=0.0.0.0
API_PORT=8300
API_DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]

# Scraper ayarları
SCRAPER_DELAY_MIN=2.0
SCRAPER_DELAY_MAX=5.0
SCRAPER_MAX_PRODUCTS_PER_CATEGORY=200
SCRAPER_CONCURRENCY=2
SCRAPER_MAX_RETRIES=3
SCRAPER_PAGE_TIMEOUT=30

# Scheduler (haftalık otomatik scraping)
SCHEDULER_ENABLED=true
SCHEDULER_CRON_DAY=sun
SCHEDULER_CRON_HOUR=12
SCHEDULER_CRON_MINUTE=0

# Loglama
LOG_LEVEL=INFO
